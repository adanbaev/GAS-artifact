<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram name="Figure 1" id="fig1">
    <mxGraphModel dx="1200" dy="900" grid="0" gridSize="10" guides="1" tooltips="1"
                  connect="1" arrows="1" fold="1" page="0" pageScale="1"
                  pageWidth="620" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ── Nodes ─────────────────────────────────────────────── -->

        <!-- 1. HTTP request (pill/terminal) -->
        <mxCell id="n1" value="HTTP request"
          style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;
                 fillColor=#D4D4D4;strokeColor=#888888;
                 fontStyle=1;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="170" y="30" width="190" height="44" as="geometry" />
        </mxCell>

        <!-- 2. Authenticated? (diamond) -->
        <mxCell id="n2" value="Authenticated?"
          style="rhombus;whiteSpace=wrap;html=1;
                 fillColor=#FDE9A2;strokeColor=#C8A030;
                 fontStyle=1;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="175" y="115" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- 3. Access denied -->
        <mxCell id="n3" value="&lt;b&gt;Access denied&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px;font-weight:normal;&apos;&gt;401 unauthorized&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;
                 fillColor=#F7C5C5;strokeColor=#C05050;
                 fontStyle=1;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="430" y="125" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- 4. Per-request temporal filter (blue — inside the auth branch) -->
        <mxCell id="n4" value="&lt;b&gt;Per-request temporal filter&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px;font-weight:normal;&apos;&gt;TrbacPerRequestFilter — every request&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;
                 fillColor=#C8DFF0;strokeColor=#5A8DB0;
                 fontStyle=1;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="120" y="240" width="290" height="60" as="geometry" />
        </mxCell>

        <!-- 5. Working hours? (diamond) -->
        <mxCell id="n5" value="&lt;b&gt;Working hours?&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px;font-weight:normal;&apos;&gt;09:00 – 18:00&lt;/font&gt;"
          style="rhombus;whiteSpace=wrap;html=1;
                 fillColor=#FDE9A2;strokeColor=#C8A030;
                 fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="155" y="350" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- 6. ADMINISTRATOR (same blue as other boxes) -->
        <mxCell id="n6" value="&lt;b&gt;ADMINISTRATOR&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px;font-weight:normal;&apos;&gt;Full write access&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;
                 fillColor=#C8DFF0;strokeColor=#5A8DB0;
                 fontStyle=1;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="490" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- 7. VIEWER (same blue as other boxes) -->
        <mxCell id="n7" value="&lt;b&gt;VIEWER&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px;font-weight:normal;&apos;&gt;Read-only (this request)&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;
                 fillColor=#C8DFF0;strokeColor=#5A8DB0;
                 fontStyle=1;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="340" y="490" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- 8. Process and respond (blue) -->
        <mxCell id="n8" value="&lt;b&gt;Process and respond&lt;/b&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;
                 fillColor=#C8DFF0;strokeColor=#5A8DB0;
                 fontStyle=1;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="160" y="605" width="210" height="50" as="geometry" />
        </mxCell>

        <!-- 9. Restore original auth (blue) -->
        <mxCell id="n9" value="&lt;b&gt;Restore original auth&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:9px;font-weight:normal;&apos;&gt;finally block — no session downgrade&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;
                 fillColor=#C8DFF0;strokeColor=#5A8DB0;
                 fontStyle=1;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="110" y="707" width="310" height="60" as="geometry" />
        </mxCell>

        <!-- ── Edges ─────────────────────────────────────────────── -->

        <!-- HTTP request → Authenticated? -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;"
          edge="1" source="n1" target="n2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Authenticated? → No → Access denied -->
        <mxCell id="e2" value="No"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;
                 exitX=1;exitY=0.5;exitDx=0;exitDy=0;
                 entryX=0;entryY=0.5;entryDx=0;entryDy=0;
                 fontStyle=2;fontSize=10;"
          edge="1" source="n2" target="n3" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points" />
          </mxGeometry>
        </mxCell>

        <!-- Authenticated? → Yes → Filter -->
        <mxCell id="e3" value="Yes"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;
                 exitX=0.5;exitY=1;exitDx=0;exitDy=0;
                 entryX=0.5;entryY=0;entryDx=0;entryDy=0;
                 fontStyle=2;fontSize=10;"
          edge="1" source="n2" target="n4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Filter → Working hours? -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;"
