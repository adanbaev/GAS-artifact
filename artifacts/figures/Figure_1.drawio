          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Working hours? → Yes → ADMINISTRATOR -->
        <mxCell id="e5" value="Yes"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;
                 exitX=0;exitY=0.5;exitDx=0;exitDy=0;
                 entryX=0.5;entryY=0;entryDx=0;entryDy=0;
                 fontStyle=2;fontSize=10;"
          edge="1" source="n5" target="n6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Working hours? → No → VIEWER -->
        <mxCell id="e6" value="No"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;
                 exitX=1;exitY=0.5;exitDx=0;exitDy=0;
                 entryX=0.5;entryY=0;entryDx=0;entryDy=0;
                 fontStyle=2;fontSize=10;"
          edge="1" source="n5" target="n7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ADMINISTRATOR → Process and respond -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;
                 exitX=0.5;exitY=1;exitDx=0;exitDy=0;
                 entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n6" target="n8" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- VIEWER → Process and respond -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;
                 exitX=0.5;exitY=1;exitDx=0;exitDy=0;
                 entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n7" target="n8" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Process and respond → Restore original auth -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;"
          edge="1" source="n8" target="n9" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
